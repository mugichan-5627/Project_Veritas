# Project Veritas — Environment Template

# LLM Provider (use one)
# Differentiated keys are preferred for hackathon partner integration (NVIDIA NIM / Fireworks)
NVIDIA_API_KEY=your_nvidia_nim_key_here
FIREWORKS_API_KEY=your_fireworks_key_here

# Search Engine
TAVILY_API_KEY=your_tavily_key_here

# Optional: Generic LLM Provider (if using a different OpenAI-compatible proxy)
# LLM_API_KEY=your_api_key_here
# LLM_BASE_URL=https://api.example.com/v1
